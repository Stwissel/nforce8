  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@snyk/protect": "^1.1303.2",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "coveralls": "^3.1.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
